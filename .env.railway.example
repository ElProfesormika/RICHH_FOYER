# === Service PostgreSQL (plugin Railway) ===
# Créer un service Postgres puis lier à l'API : DATABASE_URL est injecté automatiquement.

# === Service API (racine du repo, Dockerfile backend/Dockerfile) ===
DATABASE_URL=${{Postgres.DATABASE_URL}}
APP_DB_SQL_PATH=/data/app_db.sql
CSV_PATH=/data/Rapport vente.csv
IMPORT_SOURCE=app_db
FORCE_REIMPORT=false
SEUIL_FOURNISSEUR=400
LEAD_TIME_DAYS=3
SERVICE_LEVEL_Z=1.65
FORECAST_HORIZON_DAYS=14
# URL publique du frontend (pour CORS)
FRONTEND_URL=https://${{frontend.RAILWAY_PUBLIC_DOMAIN}}

# === Service Frontend (Root Directory = frontend) ===
# Variable de build Docker (obligatoire) :
VITE_API_BASE_URL=https://${{api.RAILWAY_PUBLIC_DOMAIN}}/api
